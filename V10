local function SetSpeedhack(enabled, multiplier)
    State.speedhack = enabled
    State.speedMultiplier = multiplier or 1.5
    
    if enabled then
        if Connections.speedhack then
            Connections.speedhack:Disconnect()
        end
        
        Connections.speedhack = RunService.Heartbeat:Connect(function()
            if not State.speedhack then return end
            
            pcall(function()
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        hum.WalkSpeed = 16 * State.speedMultiplier
                    end
                end
            end)
        end)
    end
end

-- ============================================================================
-- ANTI-CHEAT BYPASS (CONTINUOUS)
-- ============================================================================
local function ActivateBypass()
    if Connections.bypass then
        Connections.bypass:Disconnect()
    end
    
    Connections.bypass = RunService.Heartbeat:Connect(function()
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            -- Disable detection systems
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
            end
            
            -- Remove footstep sounds
            for _, sound in ipairs(char:GetDescendants()) do
                if sound:IsA("Sound") then
                    sound.Volume = 0
                end
            end
            
            -- Smooth surfaces for bypass
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.TopSurface = Enum.SurfaceType.Smooth
                    part.BottomSurface = Enum.SurfaceType.Smooth
                end
            end
        end)
    end)
end

