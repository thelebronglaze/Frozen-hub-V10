-- ============================================================================
-- ADVANCED REMOTE SYSTEM
-- ============================================================================
local RemoteCache = {}

local function FindRemote(remoteNames)
    for _, name in ipairs(remoteNames) do
        if RemoteCache[name] then
            return RemoteCache[name]
        end
        
        local locations = {
            ReplicatedStorage,
            workspace,
            LocalPlayer,
            LocalPlayer.PlayerScripts,
        }
        
        for _, location in ipairs(locations) do
            if location then
                local remote = location:FindFirstChild(name, true)
                if remote and (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) then
                    RemoteCache[name] = remote
                    return remote
                end
            end
        end
    end
    return nil
end

local function FireRemote(remoteNames, ...)
    local remote = FindRemote(remoteNames)
    if remote then
        pcall(function()
            if remote:IsA("RemoteFunction") then
                return remote:InvokeServer(...)
            else
                remote:FireServer(...)
            end
        end)
        return true
    end
    return false
end

-- ============================================================================
-- ADVANCED GODMODE (INDESTRUCTIBLE - NO DAMAGE POSSIBLE)
-- ============================================================================
local function StartGodmode()
    if Connections.godmode then
        Connections.godmode:Disconnect()
    end
    
    State.godmode = true
    State.lastDamageHealth = LocalPlayer.Character:FindFirstChildOfClass("Humanoid").MaxHealth
    
    Connections.godmode = RunService.Heartbeat:Connect(function()
        if not State.godmode then return end
        
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end
            
            -- Restore health instantly if damaged
            if hum.Health < State.lastDamageHealth then
                hum.Health = hum.MaxHealth
            end
            State.lastDamageHealth = hum.Health
            
            -- Disable all damage states
            pcall(function()
                hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
                hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
                hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
                hum:SetStateEnabled(Enum.HumanoidStateType.Flying, true)
                hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
                hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
                hum:SetStateEnabled(Enum.HumanoidStateType.RunningNoPhysics, true)
            end)
            
            -- Disable all collisions
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                    part.TopSurface = Enum.SurfaceType.Smooth
                    part.BottomSurface = Enum.SurfaceType.Smooth
                end
            end
        end)
    end)
    
    return true
end

local function StopGodmode()
    State.godmode = false
    if Connections.godmode then
        Connections.godmode:Disconnect()
        Connections.godmode = nil
    end
    
    pcall(function()
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    part.CanCollide = true
                end
            end
        end
    end)
end

